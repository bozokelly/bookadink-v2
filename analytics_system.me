## Audit SQL Queries

Use these in the Supabase SQL Editor to verify UI numbers against direct table totals.

### Verify Revenue KPIs (replace clubid and days)
```sql
-- Gross, net, platform fee, credits for a club in last 30 days
WITH games AS (
  SELECT id FROM games
  WHERE club_id = '<club_id>'
    AND status != 'cancelled'
    AND date_time >= now() - INTERVAL '30 days'
    AND date_time <= now()
),
conf AS (
  SELECT * FROM bookings
  WHERE status = 'confirmed' AND game_id IN (SELECT id FROM games)
)
SELECT
  SUM(COALESCE(platform_fee_cents,0) + COALESCE(club_payout_cents,0))
    FILTER (WHERE payment_method='stripe')                         AS gross_revenue_cents,
  SUM(COALESCE(club_payout_cents,0))
    FILTER (WHERE payment_method='stripe')                         AS net_revenue_cents,
  SUM(COALESCE(platform_fee_cents,0))
    FILTER (WHERE payment_method='stripe')                         AS platform_fee_cents,
  SUM(COALESCE(credits_applied_cents,0))                          AS credits_used_cents,
  COUNT(*) FILTER (WHERE payment_method='stripe')                  AS paid_bookings,
  COUNT(*) FILTER (WHERE payment_method IS DISTINCT FROM 'stripe') AS free_bookings,
  COUNT(DISTINCT user_id)                                          AS active_players
FROM conf;
```

### Verify Refunded (Cancelled Paid Bookings)
```sql
WITH games AS (
  SELECT id FROM games
  WHERE club_id = '<club_id>'
    AND status != 'cancelled'
    AND date_time >= now() - INTERVAL '30 days'
    AND date_time <= now()
)
SELECT
  COUNT(*)                                                         AS cancelled_paid_count,
  SUM(COALESCE(platform_fee_cents,0) + COALESCE(club_payout_cents,0)) AS cancelled_gross_cents
FROM bookings
WHERE status = 'cancelled'
  AND fee_paid = true
  AND payment_method = 'stripe'
  AND game_id IN (SELECT id FROM games);
```

### Verify No-show Rate
```sql
SELECT
  COUNT(*) FILTER (WHERE attendance_status = 'no_show') AS no_show_count,
  COUNT(*)                                               AS checked_count,
  ROUND(
    COUNT(*) FILTER (WHERE attendance_status = 'no_show')::NUMERIC
    / NULLIF(COUNT(*), 0), 4
  )                                                      AS no_show_rate
FROM game_attendance
WHERE game_id IN (
  SELECT id FROM games
  WHERE club_id = '<club_id>'
    AND status != 'cancelled'
    AND date_time >= now() - INTERVAL '30 days'
    AND date_time < now()
);
```

### Verify Trend Reconciles with KPI (sum of daily buckets = KPI total)
```sql
-- Should match net_revenue_cents from KPI query above
WITH games AS (
  SELECT id, date_time::DATE AS d FROM games
  WHERE club_id = '<club_id>'
    AND status != 'cancelled'
    AND date_time >= now() - INTERVAL '30 days'
    AND date_time <= now()
)
SELECT SUM(COALESCE(b.club_payout_cents,0)) AS trend_total_net_cents
FROM bookings b
JOIN games g ON g.id = b.game_id
WHERE b.status = 'confirmed' AND b.payment_method = 'stripe';
```

### Verify Fill Rate
```sql
WITH games AS (
  SELECT id, max_spots FROM games
  WHERE club_id = '<club_id>'
    AND status != 'cancelled'
    AND date_time >= now() - INTERVAL '30 days'
    AND date_time <= now()
    AND max_spots IS NOT NULL AND max_spots > 0
),
fills AS (
  SELECT g.max_spots, COUNT(b.id) AS conf
  FROM games g
  LEFT JOIN bookings b ON b.game_id = g.id AND b.status = 'confirmed'
  GROUP BY g.id, g.max_spots
)
SELECT
  SUM(conf) AS total_confirmed,
  SUM(max_spots) AS total_capacity,
  ROUND(SUM(conf)::NUMERIC / NULLIF(SUM(max_spots), 0), 4) AS fill_rate
FROM fills;
```

### Verify Club Isolation (no cross-club leakage)
```sql
-- Should return 0 for any club other than the one queried
SELECT COUNT(*) FROM bookings b
JOIN games g ON g.id = b.game_id
WHERE g.club_id != '<club_id>'
  AND b.game_id IN (
    SELECT id FROM games WHERE club_id = '<club_id>'
  );
```

